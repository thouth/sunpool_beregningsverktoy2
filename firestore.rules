rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- PRIMITIVE DEFINITIONS ---
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return request.auth.token.email_verified == true; }
    function isAdmin() { return isSignedIn() && request.auth.token.email == 'thuthaug@gmail.com'; } // Bootstrapped Admin

    // --- BLUEPRINTS ---
    function isValidUser(data) {
      // 4 mandatory fields
      return data.keys().hasAll(['uid', 'email', 'createdAt', 'updatedAt']) 
        && data.keys().size() == 4
        && data.uid == request.auth.uid
        && data.email is string && data.email.size() <= 254
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function isValidProject(data) {
      // 7 fields total (5 required, 2 optional standard)
      return data.keys().hasAll(['userId', 'userEmail', 'address', 'createdAt', 'updatedAt'])
        && data.keys().size() >= 5 && data.keys().size() <= 7
        && data.userId == request.auth.uid
        && data.userEmail is string && data.userEmail.size() <= 254
        && data.address is string && data.address.size() <= 250
        && data.createdAt is timestamp
        && data.updatedAt is timestamp
        && (data.keys().hasAll(['targetLocation']) ? (data.targetLocation is list && data.targetLocation.size() <= 2) : true)
        && (data.keys().hasAll(['simulationData']) ? (data.simulationData is map && data.simulationData.size() <= 20) : true);
    }

    // --- PATHS ---
    
    // USERS COLLECTION
    match /users/{userId} {
      allow get: if isSignedIn() && isValidId(userId) && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin() && existing().keys().hasAny(['uid']); // Prevent blind scraping unless admin
      
      allow create: if isSignedIn() 
        && isValidId(userId) 
        && request.auth.uid == userId 
        && isValidUser(incoming())
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;
        
      allow update: if isSignedIn() 
        && isValidId(userId) 
        && request.auth.uid == userId 
        && isValidUser(incoming())
        && incoming().uid == existing().uid
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && incoming().diff(existing()).affectedKeys().hasOnly(['updatedAt']);
        
      allow delete: if false; // Users shouldn't be deleted via client
    }

    // PROJECTS COLLECTION
    match /projects/{projectId} {
      // Secure List Queries
      allow list: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      
      allow get: if isSignedIn() && isValidId(projectId) && (existing().userId == request.auth.uid || isAdmin());

      allow create: if isSignedIn()
        && isValidId(projectId)
        && isValidProject(incoming())
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time
        && exists(/databases/$(database)/documents/users/$(incoming().userId)); // 8. Global Consistency Invariant

      allow update: if isSignedIn()
        && isValidId(projectId)
        && existing().userId == request.auth.uid
        && isValidProject(incoming())
        && (isAdmin() || (
           incoming().userId == existing().userId
           && incoming().userEmail == existing().userEmail
           && incoming().createdAt == existing().createdAt
           && incoming().updatedAt == request.time
           && incoming().diff(existing()).affectedKeys().hasOnly(['address', 'targetLocation', 'simulationData', 'updatedAt'])
        ));

      allow delete: if isSignedIn() && isValidId(projectId) && (existing().userId == request.auth.uid || isAdmin());
    }
  }
}
